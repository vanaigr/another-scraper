generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}
datasource db {
  provider = "sqlite"
}

model job {
    id String @id
    time Int

    companyUrl String
    companyName String

    jobTitle String
    jobLocation String

    jobDescription String
    jobDescriptionHtml String

    easyApply Boolean @default(false)
}

model status {
    id String @id
    status String
}
